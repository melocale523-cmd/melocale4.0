# ═══════════════════════════════════════════════
# MeloCalé 4.0 — Backend Environment Variables
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env com valores reais
# ═══════════════════════════════════════════════

# ── Supabase ──────────────────────────────────
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # Chave service_role (secreta — nunca expor no frontend)

# ── Stripe ────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...     # ou sk_test_... para ambiente de teste
STRIPE_WEBHOOK_SECRET=whsec_...   # Secret do webhook no dashboard Stripe

# Stripe Price IDs — Planos mensais (criados no Stripe Dashboard)
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ELITE=price_xxx

# Stripe Price IDs — Pacotes de moedas avulsas (criados no Stripe Dashboard)
STRIPE_PRICE_PACK_BASIC=price_xxx
STRIPE_PRICE_PACK_POPULAR=price_xxx
STRIPE_PRICE_PACK_MAX=price_xxx

# Stripe Price IDs — Pacotes com desconto por plano ativo (Opção A)
STRIPE_PRICE_PACK_BASIC_STARTER=price_xxx
STRIPE_PRICE_PACK_BASIC_PRO=price_xxx
STRIPE_PRICE_PACK_BASIC_ELITE=price_xxx
STRIPE_PRICE_PACK_POPULAR_STARTER=price_xxx
STRIPE_PRICE_PACK_POPULAR_PRO=price_xxx
STRIPE_PRICE_PACK_POPULAR_ELITE=price_xxx
STRIPE_PRICE_PACK_MAX_STARTER=price_xxx
STRIPE_PRICE_PACK_MAX_PRO=price_xxx
STRIPE_PRICE_PACK_MAX_ELITE=price_xxx

# ── Web Push / VAPID ──────────────────────────
VAPID_PUBLIC_KEY=BK...            # Chave pública (pode ser exposta no frontend)
VAPID_PRIVATE_KEY=...             # Chave privada (secreta — nunca expor)
VAPID_EMAIL=mailto:contato@melocale.com.br

# ── Anthropic (IA) ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...      # Chave da API Anthropic
# ── Marketing IA (Claude + Gemini/Nano Banana) ───────────────────────────────
# Claude usa ANTHROPIC_API_KEY acima. O Gemini só é ativado quando esta chave existe.
GOOGLE_GENERATIVE_AI_API_KEY=    # Chave do Google AI Studio (nunca expor no frontend)
SOCIAL_STRATEGY_MODEL=claude-sonnet-4-5
SOCIAL_ECONOMY_MODEL=claude-haiku-4-5-20251001
# economy por padrao; use quality apenas para campanhas premium.
SOCIAL_STRATEGY_MODE=economy
SOCIAL_VISUAL_MODEL=gemini-3.1-flash-image-preview
SOCIAL_VISUAL_FALLBACK_MODEL=gpt-image-1-mini
SOCIAL_VISUAL_FALLBACK_ENABLED=false
# Habilita pesquisa web paga do Claude somente após conferir orçamento e política editorial.
SOCIAL_RESEARCH_ENABLED=false
# Opcional: para registrar custo estimado sem fixar preços no código.
SOCIAL_STRATEGY_INPUT_CENTS_PER_MTOKEN=0
SOCIAL_STRATEGY_OUTPUT_CENTS_PER_MTOKEN=0
SOCIAL_VISUAL_CENTS_PER_IMAGE=0
# Controles conservadores do autopilot: uma pauta/dia e US$ 1/dia por padrao.
SOCIAL_AUTOPILOT_INTERVAL_MINUTES=1440
SOCIAL_AUTOPILOT_MAX_ITEMS_PER_RUN=1
SOCIAL_AUTOPILOT_DAILY_LIMIT_CENTS=100
SOCIAL_AUTOMATION_ITEM_RESERVE_CENTS=15
SOCIAL_VISUAL_RESERVE_CENTS=25
SOCIAL_AUTOPILOT_ALLOW_IMAGES=false
MELOCALE_BRAND_LOGO_URL=https://www.melocale.com.br/apple-touch-icon.png
# Publicação no Instagram: valores exclusivos do backend/Render.
META_INSTAGRAM_ACCESS_TOKEN=
META_INSTAGRAM_ACCOUNT_ID=
# Opcional: deixe vazio para usar a versão padrão da API da Meta.
META_INSTAGRAM_GRAPH_API_VERSION=

# ── Aplicação ─────────────────────────────────
NODE_ENV=production               # production | development
FRONTEND_URL=https://melocale.com.br   # URL do frontend (para CORS)

# ── Telegram (alertas de auditoria) ──────────
TELEGRAM_BOT_TOKEN=          # Token do bot (@BotFather)
TELEGRAM_CHAT_ID=            # ID do chat/grupo que recebe alertas

# ── Meta Conversions API ──────────────────────
META_PIXEL_ID=                        # ID do Pixel Meta (ex: 1022262010473244)
META_ACCESS_TOKEN=                    # Token de acesso do sistema Meta

# ── Testes E2E (apenas em CI/desenvolvimento) ──
E2E_CLIENT_EMAIL=cliente@exemplo.com
E2E_CLIENT_PASSWORD=senha_segura
E2E_PROF_EMAIL=profissional@exemplo.com
E2E_PROF_PASSWORD=senha_segura

# Ative somente depois de aplicar a migration automation_job_runs no Supabase
AUTOMATION_RUN_HISTORY_ENABLED=false

AUTOMATION_QUEUE_ENABLED=false

# Enables the scheduled Marketing IA content worker (approval is still required before publishing).
SOCIAL_AUTOPILOT_ENABLED=false
