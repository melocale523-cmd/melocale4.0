# ═══════════════════════════════════════════════
# MeloCalé 4.0 — Backend Environment Variables
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env com valores reais
# ═══════════════════════════════════════════════

# ── Supabase ──────────────────────────────────
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # Chave service_role (secreta — nunca expor no frontend)

# ── Stripe ────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...     # ou sk_test_... para ambiente de teste
STRIPE_WEBHOOK_SECRET=whsec_...   # Secret do webhook no dashboard Stripe

# Stripe Price IDs — Planos mensais (criados no Stripe Dashboard)
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ELITE=price_xxx

# Stripe Price IDs — Pacotes de moedas avulsas (criados no Stripe Dashboard)
STRIPE_PRICE_PACK_BASIC=price_xxx
STRIPE_PRICE_PACK_POPULAR=price_xxx
STRIPE_PRICE_PACK_MAX=price_xxx

# Stripe Price IDs — Pacotes com desconto por plano ativo (Opção A)
STRIPE_PRICE_PACK_BASIC_STARTER=price_xxx
STRIPE_PRICE_PACK_BASIC_PRO=price_xxx
STRIPE_PRICE_PACK_BASIC_ELITE=price_xxx
STRIPE_PRICE_PACK_POPULAR_STARTER=price_xxx
STRIPE_PRICE_PACK_POPULAR_PRO=price_xxx
STRIPE_PRICE_PACK_POPULAR_ELITE=price_xxx
STRIPE_PRICE_PACK_MAX_STARTER=price_xxx
STRIPE_PRICE_PACK_MAX_PRO=price_xxx
STRIPE_PRICE_PACK_MAX_ELITE=price_xxx

# ── Web Push / VAPID ──────────────────────────
VAPID_PUBLIC_KEY=BK...            # Chave pública (pode ser exposta no frontend)
VAPID_PRIVATE_KEY=...             # Chave privada (secreta — nunca expor)
VAPID_EMAIL=mailto:contato@melocale.com.br

# ── Anthropic (IA) ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...      # Chave da API Anthropic

# ── Aplicação ─────────────────────────────────
NODE_ENV=production               # production | development
FRONTEND_URL=https://melocale.com.br   # URL do frontend (para CORS)

# ── Telegram (alertas de auditoria) ──────────
TELEGRAM_BOT_TOKEN=          # Token do bot (@BotFather)
TELEGRAM_CHAT_ID=            # ID do chat/grupo que recebe alertas

# ── Meta Conversions API ──────────────────────
META_PIXEL_ID=                        # ID do Pixel Meta (ex: 1022262010473244)
META_ACCESS_TOKEN=                    # Token de acesso do sistema Meta

# ── Testes E2E (apenas em CI/desenvolvimento) ──
E2E_CLIENT_EMAIL=cliente@exemplo.com
E2E_CLIENT_PASSWORD=senha_segura
E2E_PROF_EMAIL=profissional@exemplo.com
E2E_PROF_PASSWORD=senha_segura
