VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Server-side only: usado pela Edge Function de SEO para consultar profissionais via RPC protegida.
# Nao usar com prefixo VITE_ e nao expor no client bundle.
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Sitekey pública do Cloudflare Turnstile (não é segredo) — usada pelo widget
# invisível de captcha em signUp/signInWithPassword/resetPasswordForEmail.
# Precisa estar configurada também no Vercel (Production + Preview), senão
# essas chamadas ao Supabase Auth falham com "captcha verification failed"
# assim que Attack Protection > Captcha estiver ativado no projeto Supabase.
VITE_TURNSTILE_SITE_KEY=0x4AAAAAADxRzPDcHxqqfXWi

# URL do backend no Render
VITE_API_URL=https://melocale4-0.onrender.com

# Chave pública VAPID para Web Push (gerada com web-push generate-vapid-keys)
VITE_VAPID_PUBLIC_KEY=BK...

# Sentry (error monitoring — production only)
VITE_SENTRY_DSN=
